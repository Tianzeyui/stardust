{
  "name": "stardust-desktop",
  "private": true,
  "type": "module",
  "version": "0.23.0",
  "description": "Stardust Desktop - Electron + React + TypeScript",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:rust": "cargo watch -w stardust-engine/src -x build",
    "dev:all": "npm run dev:rust & npm run dev",
    "build": "vite build",
    "preview": "vite preview",
    "build:electron": "npm run build && electron-builder",
    "build:mac": "npm run build && electron-builder --mac",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.1.1",
    "@supabase/supabase-js": "^2.106.2",
    "@uiw/react-markdown-preview": "^5.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "esbuild": "^0.28.0",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "neo4j-driver": "^6.1.0",
    "node-llama-cpp": "^3.18.1",
    "node-pty": "^1.1.0",
    "officeparser": "^7.1.0",
    "ogl": "^1.0.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.stardust.desktop",
    "productName": "Stardust",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "public/**/*"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**"
    ],
    "extraResources": [
      {
        "from": "stardust-engine/target/release/stardust-engine",
        "to": "sidecar/stardust-engine"
      },
      {
        "from": "stardust-engine/target/release/stardust-engine.exe",
        "to": "sidecar/stardust-engine.exe"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "public/assets/icons/icon.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "public/assets/icons/icon.png",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "icon": "public/assets/icons/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "maintainer": "tianzeyu@outlook.com"
    }
  },
  "repository": "https://github.com/Tianzeyui/stardust.git",
  "author": "沉浸位工作室"
}
